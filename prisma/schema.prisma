// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================================
// NextAuth.js required models
// ============================================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts          Account[]
  sessions          Session[]
  whatsappAccounts  WhatsAppAccount[]
  excelFiles        ExcelFile[]
  messageTemplates  MessageTemplate[]
  messageHistories  MessageHistory[]
  appConfig         AppConfig?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================================
// Application models
// ============================================================

model WhatsAppAccount {
  id            String    @id @default(cuid())
  userId        String
  phoneNumber   String
  displayName   String
  /// One of: DISCONNECTED | CONNECTING | CONNECTED | QR_READY
  status        String    @default("DISCONNECTED")
  /// AES-256-GCM encrypted session data
  sessionData   String?
  lastConnected DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  messageHistories MessageHistory[]
}

model ExcelFile {
  id                String   @id @default(cuid())
  userId            String
  fileName          String
  filePath          String
  /// JSON-encoded array of column name strings
  columns           String   @default("[]")
  rowCount          Int      @default(0)
  validNumbers      Int      @default(0)
  invalidNumbers    Int      @default(0)
  phoneNumberColumn String?
  parsedAt          DateTime @default(now())
  createdAt         DateTime @default(now())

  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  messageHistories MessageHistory[]
}

model MessageTemplate {
  id           String   @id @default(cuid())
  userId       String
  name         String
  content      String
  /// JSON-encoded array of placeholder name strings
  placeholders String   @default("[]")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  messageHistories MessageHistory[]
}

model MessageHistory {
  id                String    @id @default(cuid())
  userId            String
  whatsappAccountId String
  templateId        String?
  excelFileId       String
  messageContent    String
  totalRecipients   Int       @default(0)
  successCount      Int       @default(0)
  failureCount      Int       @default(0)
  skippedCount      Int       @default(0)
  delaySeconds      Int       @default(30)
  /// One of: PENDING | SENDING | COMPLETED | FAILED
  status            String    @default("PENDING")
  startedAt         DateTime  @default(now())
  completedAt       DateTime?

  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  whatsappAccount WhatsAppAccount @relation(fields: [whatsappAccountId], references: [id])
  template        MessageTemplate? @relation(fields: [templateId], references: [id])
  excelFile       ExcelFile       @relation(fields: [excelFileId], references: [id])
  deliveryResults DeliveryResult[]
}

model DeliveryResult {
  id           String    @id @default(cuid())
  historyId    String
  phoneNumber  String
  /// One of: PENDING | SENT | FAILED
  status       String    @default("PENDING")
  errorMessage String?
  sentAt       DateTime?
  retryCount   Int       @default(0)

  history MessageHistory @relation(fields: [historyId], references: [id], onDelete: Cascade)
}

model AppConfig {
  id                   String   @id @default(cuid())
  userId               String   @unique
  delayMin             Int      @default(20000)
  delayMax             Int      @default(40000)
  maxRetries           Int      @default(3)
  /// One of: debug | info | warn | error
  logLevel             String   @default("info")
  sessionEncryptionKey String?
  maxAccountsPerUser   Int      @default(10)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
