# =============================================================
# COPY FILE INI MENJADI .env.local DAN ISI DENGAN NILAI ASLI
# cp .env.example .env.local
# =============================================================

# --- Database ---
# SQLite (default untuk development)
DATABASE_URL="file:./dev.db"

# --- NextAuth ---
# URL aplikasi (ubah ke domain production saat deploy)
NEXTAUTH_URL="http://localhost:3000"
# Generate dengan: openssl rand -hex 32
NEXTAUTH_SECRET="your-nextauth-secret-here"

# --- Google OAuth ---
# Buat di: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# --- Encryption ---
# Generate dengan: openssl rand -hex 16
ENCRYPTION_KEY="your-32-char-hex-encryption-key"